// Prisma schema for Arrow Maze backend.
//
// Architecture note: this schema and the generated Prisma Client are an
// INFRASTRUCTURE detail. Only `src/infrastructure` may import `@prisma/client`.
// `src/domain` and `src/application` must never depend on the ORM.
//
// Models use camelCase fields mapped to the existing snake_case columns/tables
// via `@map`/`@@map`, so the database layout is unchanged while the client API
// stays idiomatic. `@db` types mirror the schema produced by the original SQL
// migrations (now baselined under prisma/migrations).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String             @id @db.Uuid
  email              String             @unique @db.VarChar(255)
  username           String             @unique @db.VarChar(30)
  passwordHash       String             @map("password_hash")
  role               String             @default("USER") @db.VarChar(10)
  status             String             @default("ACTIVE") @db.VarChar(10)
  createdAt          DateTime           @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @map("updated_at") @db.Timestamptz(6)
  leaderboardEntries LeaderboardEntry[]
  playerProgress     PlayerProgress?
  refreshTokens      RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id                String    @id @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  tokenHash         String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt         DateTime  @map("created_at") @db.Timestamptz(6)
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedByTokenId String?   @map("replaced_by_token_id") @db.Uuid
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_refresh_tokens_user_id")
  @@map("refresh_tokens")
}

model Leaderboard {
  id         String             @id @db.Uuid
  levelId    String             @unique @map("level_id") @db.Uuid
  maxEntries Int                @default(10) @map("max_entries")
  updatedAt  DateTime           @map("updated_at") @db.Timestamptz(6)
  level      Level              @relation(fields: [levelId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  entries    LeaderboardEntry[]

  @@map("leaderboards")
}

model LeaderboardEntry {
  id               String      @id @db.Uuid
  leaderboardId    String      @map("leaderboard_id") @db.Uuid
  userId           String      @map("user_id") @db.Uuid
  levelId          String      @map("level_id") @db.Uuid
  usernameSnapshot String      @map("username_snapshot") @db.VarChar(255)
  score            Int
  timeSeconds      Decimal     @map("time_seconds") @db.Decimal
  movesCount       Int         @map("moves_count")
  rank             Int?
  submittedAt      DateTime    @map("submitted_at") @db.Timestamptz(6)
  leaderboard      Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user             User        @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@unique([leaderboardId, userId])
  @@index([leaderboardId], map: "idx_leaderboard_entries_leaderboard_id")
  @@map("leaderboard_entries")
}

model PlayerProgress {
  id              String           @id @db.Uuid
  userId          String           @unique @map("user_id") @db.Uuid
  version         Int              @default(0)
  updatedAt       DateTime         @map("updated_at") @db.Timestamptz(6)
  user            User             @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  completedLevels CompletedLevel[]

  @@map("player_progress")
}

model CompletedLevel {
  id              String         @id @db.Uuid
  progressId      String         @map("progress_id") @db.Uuid
  levelId         String         @map("level_id") @db.Uuid
  bestScore       Int            @map("best_score")
  bestTimeSeconds Decimal        @map("best_time_seconds") @db.Decimal
  bestMovesCount  Int            @map("best_moves_count")
  completedAt     DateTime       @map("completed_at") @db.Timestamptz(6)
  updatedAt       DateTime       @map("updated_at") @db.Timestamptz(6)
  progress        PlayerProgress @relation(fields: [progressId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  level           Level          @relation(fields: [levelId], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@unique([progressId, levelId])
  @@index([progressId], map: "idx_completed_levels_progress_id")
  @@map("completed_levels")
}

model Level {
  id               String   @id @db.Uuid
  name             String   @db.VarChar(100)
  description      String   @default("") @db.VarChar(500)
  difficulty       String   @db.VarChar(10)
  status           String   @default("DRAFT") @db.VarChar(10)
  version          Int      @default(1)
  arrows           Json     @default("[]")
  attempts         Int      @default(5)
  timeLimitSeconds Int?     @map("time_limit_seconds")
  dimensions       Int      @default(2)
  boardShape       Json?    @map("board_shape")
  createdAt        DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @map("updated_at") @db.Timestamptz(6)
  leaderboards     Leaderboard[]
  completedLevels  CompletedLevel[]

  @@index([status], map: "idx_levels_status")
  @@map("levels")
}

model DailyChallenge {
  date             String   @id @db.VarChar(10)
  seed             String   @db.VarChar(32)
  targetDifficulty String   @map("target_difficulty") @db.VarChar(10)
  source           String   @db.VarChar(20)
  level            Json
  validation       Json
  generatedAt      DateTime @map("generated_at") @db.Timestamptz(6)
  expiresAt        DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt        DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @map("updated_at") @db.Timestamptz(6)

  @@map("daily_challenges")
}

model DailyChallengeIteration {
  operationId String    @id @map("operation_id") @db.Uuid
  date        String    @db.VarChar(10)
  status      String    @db.VarChar(12)
  requestedAt DateTime  @map("requested_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  events      Json
  challenge   Json?
  createdAt   DateTime  @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @map("updated_at") @db.Timestamptz(6)

  // A partial UNIQUE index on (date) WHERE status = 'RUNNING' also exists as a
  // DB-level backstop for "one running iteration per date". Prisma cannot express
  // partial indexes in the schema, so it lives only in the migration SQL
  // (uniq_daily_challenge_iterations_running_date).
  @@index([date, status], map: "idx_daily_challenge_iterations_date_status")
  @@map("daily_challenge_iterations")
}
