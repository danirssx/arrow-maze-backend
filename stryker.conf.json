{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Backend is ESM + ts-jest. Run via the `npm run mutation` script so NODE_OPTIONS=--experimental-vm-modules is inherited by the Stryker test-runner workers. See docs/mutation-testing.md.",
  "packageManager": "npm",
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.ts",
    "enableFindRelatedTests": true
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/domain/**/*.ts",
    "src/application/**/*.ts",
    "!src/**/*.d.ts",
    "!src/**/index.ts",
    "!src/**/ports/**",
    "!src/**/*Port.ts",
    "!src/**/*Repository.ts"
  ],
  "ignorePatterns": ["dist", "coverage", "reports", ".stryker-tmp"],
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": { "fileName": "reports/mutation/index.html" },
  "thresholds": { "high": 90, "low": 80, "break": 80 },
  "concurrency": 4,
  "timeoutMS": 60000
}
