NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:8081

# Local PostgreSQL (Docker):
# DATABASE_URL=postgresql://arrow_maze:arrow_maze@localhost:5432/arrow_maze
# DATABASE_SSL=false

# Cloud PostgreSQL (Neon / Supabase / Railway / Render):
# DATABASE_URL=postgresql://user:pass@host/dbname
# DATABASE_SSL=true   # required by all cloud providers; defaults to true when NODE_ENV=production

JWT_SECRET=replace-with-local-development-secret

# Auth token lifetimes (optional). Access tokens are renewed via POST
# /auth/refresh; refresh tokens are long-lived, rotating and revocable.
# JWT_ACCESS_EXPIRES_IN=15m
# REFRESH_TOKEN_TTL_DAYS=30
